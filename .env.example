# =====================================================
# LEXDOC - CONFIGURATION ENVIRONNEMENT
# =====================================================
# Copier ce fichier vers .env et remplacer les valeurs

# =====================================================
# DOMAINE
# =====================================================
# Votre domaine principal (sans https://)
DOMAIN=votre-domaine.fr

# URLs générées automatiquement:
# - Frontend:      https://lexdoc.votre-domaine.fr
# - API:           https://api.lexdoc.votre-domaine.fr
# - MinIO API:     https://minio.lexdoc.votre-domaine.fr
# - MinIO Console: https://minio-console.lexdoc.votre-domaine.fr
# - Health:        https://health.lexdoc.votre-domaine.fr

# =====================================================
# BASE DE DONNÉES (PostgreSQL)
# =====================================================
# Credentials PostgreSQL pour le container Docker
POSTGRES_USER=lexdoc_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=lexdoc_production

# Note: La DATABASE_URL est construite automatiquement dans docker-compose.yml
# Format: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# =====================================================
# MINIO (Stockage S3 - dédié LexDoc)
# =====================================================
# Credentials admin MinIO (minimum 8 caractères chacun)
MINIO_ROOT_USER=lexdoc_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_16_CHARS

# =====================================================
# SÉCURITÉ - SECRETS JWT
# =====================================================
# Générer avec: openssl rand -base64 64

# Secret JWT pour tokens d'accès (64+ caractères)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64

# Secret JWT pour tokens de refresh (64+ caractères, différent du premier)
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_64_DIFFERENT

# =====================================================
# SÉCURITÉ - CHIFFREMENT DONNÉES
# =====================================================
# Clé AES-256 pour chiffrer données sensibles (exactement 32 caractères)
# Générer avec: openssl rand -hex 16
ENCRYPTION_KEY=CHANGE_ME_EXACTLY_32_CHARACTERS!

# =====================================================
# EMAIL - SENDGRID
# =====================================================
# API Key SendGrid pour envoi d'emails transactionnels
# Créer sur: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =====================================================
# INTÉGRATIONS EXTERNES (Phase 6 - optionnel pour MVP)
# =====================================================
# Laisser vide si non utilisé pour le moment

# Universign - Signature électronique qualifiée
UNIVERSIGN_API_KEY=

# SendingBox - Envoi LRAR (Lettre Recommandée AR)
SENDINGBOX_API_KEY=

# =====================================================
# CONFIGURATION AVANCÉE (optionnel)
# =====================================================
# Node environment
NODE_ENV=production

# Timezone serveur
TZ=Europe/Paris
