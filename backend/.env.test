# Test Environment Configuration
NODE_ENV=test
PORT=3001

# Database (PostgreSQL) - Use test database
DATABASE_URL="postgresql://lexdoc_user:lexdoc_secure_password@localhost:5434/lexdoc_production?schema=public"

# JWT Configuration
JWT_SECRET=test-jwt-secret-key-for-testing-purposes-32chars
