# Application
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000

# Frontend URL
FRONTEND_URL=http://localhost:4001

# Database (port 5434 pour éviter conflit)
DATABASE_URL="postgresql://lexdoc_user:lexdoc_dev_password_2026@localhost:5434/lexdoc_dev?schema=public"

# JWT
JWT_SECRET=dev_jwt_secret_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# MinIO (ports 9003/9004 pour éviter conflit)
MINIO_ENDPOINT=localhost
MINIO_PORT=9003
MINIO_ACCESS_KEY=lexdoc_minio_dev
MINIO_SECRET_KEY=lexdoc_minio_dev_secret_2026
MINIO_USE_SSL=false
MINIO_BUCKET=lexdoc-dev

# Encryption
ENCRYPTION_KEY=dev_encryption_key_32_chars_min_change_in_prod

# Email (development - console output)
SMTP_HOST=localhost
SMTP_PORT=1026
SMTP_USER=
SMTP_PASS=
SMTP_FROM=dev@lexdoc.local

# Universign (sandbox)
UNIVERSIGN_URL=https://sign-sandbox.universign.com/api/v1
UNIVERSIGN_API_KEY=your_universign_sandbox_key
UNIVERSIGN_CALLBACK_URL=http://localhost:4000/api/webhooks/universign

# SendingBox (sandbox)
SENDINGBOX_API_URL=https://api-sandbox.sendingbox.com
SENDINGBOX_API_KEY=your_sendingbox_sandbox_key

# Cron jobs
ENABLE_REMINDERS=true
REMINDER_CRON_SCHEDULE=0 10 * * *

# Logs - Daily Rotation Configuration
LOG_LEVEL=debug
LOG_DIR=logs
LOG_MAX_SIZE=20m
LOG_MAX_DAYS=30d
LOG_MAX_FILES=14
LOG_COMPRESS=true
LOG_ACCESS=false

# Sentry (Error Monitoring)
# Get your DSN from https://sentry.io
# Leave empty to disable Sentry in development
SENTRY_DSN=
