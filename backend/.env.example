# ===========================================
# LexDoc Backend - Environment Configuration
# ===========================================

# Application
NODE_ENV=development
PORT=3000

# URLs
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL="postgresql://lexdoc_user:your_secure_password@localhost:5432/lexdoc_production?schema=public"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (for sensitive data like 2FA secrets)
ENCRYPTION_KEY=your-32-character-encryption-key!

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MinIO Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9002
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DOCUMENTS=lexdoc-documents
MINIO_BUCKET_TEMPLATES=lexdoc-templates

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@lexdoc.fr

# ===========================================
# Phase 6: External Integrations
# ===========================================

# Universign (Electronic Signature)
UNIVERSIGN_API_KEY=your-universign-api-key
UNIVERSIGN_API_URL=https://ws.universign.eu/v1
UNIVERSIGN_WEBHOOK_SECRET=your-universign-webhook-secret

# SendingBox (LRAR - Registered Mail)
SENDINGBOX_API_KEY=your-sendingbox-api-key
SENDINGBOX_API_URL=https://api.sendingbox.io/v1
SENDINGBOX_WEBHOOK_SECRET=your-sendingbox-webhook-secret

# ===========================================
# Production Environment Example
# ===========================================
# NODE_ENV=production
# PORT=3000
# BACKEND_URL=https://api.lexdoc.example.com
# FRONTEND_URL=https://app.lexdoc.example.com
# DATABASE_URL="postgresql://lexdoc_user:STRONG_PASSWORD@postgres:5432/lexdoc_production?schema=public"
# JWT_SECRET=generate-with-openssl-rand-base64-64
# ENCRYPTION_KEY=generate-with-openssl-rand-base64-32
# CORS_ORIGINS=https://app.lexdoc.example.com
# MINIO_USE_SSL=true
# LOG_LEVEL=info
