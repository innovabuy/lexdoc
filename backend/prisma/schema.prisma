  userId      String      @map("user_id")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  wizardType  WizardType
  currentStep Int         @default(0) @map("current_step")
  totalSteps  Int         @map("total_steps")
  data        Json        @default("{}")

  completed   Boolean     @default(false)
  completedAt DateTime?   @map("completed_at")
  abandonedAt DateTime?   @map("abandoned_at")

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@unique([userId, wizardType])
  @@index([userId, wizardType, completed])
  @@map("wizard_progress")
}

enum WizardType {
  ONBOARDING
  FOLDER_CREATION
  DOCUMENT_GENERATION
  CLIENT_CREATION
}

// ============================================
// BACKUP SYSTEM MODELS
// ============================================

/// Track backup operations for audit and restoration
model BackupLog {
  id          String       @id @default(uuid())
  backupId    String       @unique @map("backup_id")

  status      BackupStatus @default(IN_PROGRESS)
  provider    String       @default("GOOGLE_DRIVE") // GOOGLE_DRIVE, AWS_S3, LOCAL

  duration    Float?       // Duration in seconds
  error       String?      // Error message if failed

  // Metadata about the backup
  metadata    Json?        // Sizes, file counts, etc.

  // Timestamps
  startedAt   DateTime     @default(now()) @map("started_at")
  completedAt DateTime?    @map("completed_at")

  @@index([status, startedAt])
  @@index([provider])
  @@map("backup_logs")
}

enum BackupStatus {
  IN_PROGRESS
  SUCCESS
  FAILED
}

// ============================================
// DOCUMENT TRACKING SYSTEM
// ============================================

/// Track document delivery status (signature, LRAR) with automatic reminders
model DocumentTracking {
  id                   String                @id @default(uuid())
  documentId           String                @unique @map("document_id")
  document             Document              @relation(fields: [documentId], references: [id], onDelete: Cascade)

  status               DocumentTrackingStatus @default(DRAFT)
  deliveryMethod       DeliveryMethod?       @map("delivery_method")

  // Signature electronique
  signatureRequestId   String?               @map("signature_request_id")
  signatureStatus      TrackingSignatureStatus? @map("signature_status")
  signedAt             DateTime?             @map("signed_at")
  signedBy             String[]              @default([]) @map("signed_by")
  expiresAt            DateTime?             @map("expires_at")

  // LRAR
  lrarRequestId        String?               @map("lrar_request_id")
  lrarTrackingNumber   String?               @map("lrar_tracking_number")
  lrarStatus           TrackingLrarStatus?   @map("lrar_status")
  sentAt               DateTime?             @map("sent_at")
  deliveredAt          DateTime?             @map("delivered_at")

  // Relances automatiques
  reminderCount        Int                   @default(0) @map("reminder_count")
  lastReminderAt       DateTime?             @map("last_reminder_at")
  nextReminderAt       DateTime?             @map("next_reminder_at")
  autoRemindersEnabled Boolean               @default(true) @map("auto_reminders_enabled")
  reminderFrequency    ReminderFrequency     @default(DAILY) @map("reminder_frequency")
  maxReminders         Int                   @default(5) @map("max_reminders")

  // Recipients for tracking
  recipients           Json                  @default("[]") // [{name, email, status, signedAt}]

  // Metadata
  customMessage        String?               @map("custom_message") @db.Text
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  // Reminder logs
  reminderLogs         ReminderLog[]

  @@index([status])
  @@index([signatureRequestId])
  @@index([lrarRequestId])
  @@index([nextReminderAt])
  @@index([documentId])
  @@map("document_tracking")
}

enum DocumentTrackingStatus {
  DRAFT              // Document cree, pas encore envoye
  PENDING_SIGNATURE  // Envoye pour signature, en attente
  PARTIALLY_SIGNED   // Au moins un signataire a signe
  SIGNED             // Signe par tous les signataires
  PENDING_DELIVERY   // Envoye en LRAR, en cours d'acheminement
  DELIVERED          // LRAR livre avec AR
  CANCELLED          // Annule
  EXPIRED            // Expire sans signature/livraison
  FAILED             // Echec d'envoi
}

enum DeliveryMethod {
  SIGNATURE_ELECTRONIQUE
  LRAR
  BOTH  // Signe puis envoye en LRAR
}

enum TrackingSignatureStatus {
  PENDING
  IN_PROGRESS   // Au moins 1 signataire a signe
  COMPLETED
  CANCELLED
  EXPIRED
}

enum TrackingLrarStatus {
  PENDING
  SENT
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
}

enum ReminderFrequency {
  DAILY
  EVERY_2_DAYS
  EVERY_3_DAYS
  WEEKLY
}

// ============================================
// CLIENT EXTRANET SYSTEM
// ============================================

/// Client portal access for external clients
model ClientAccess {
  id                String            @id @default(cuid())
  email             String            @unique
  firstName         String?           @map("first_name")
  lastName          String?           @map("last_name")
  companyName       String?           @map("company_name")

  // Authentication
  passwordHash      String?           @map("password_hash")
  isActivated       Boolean           @default(false) @map("is_activated")
  activationToken   String?           @unique @map("activation_token")
  activationExpires DateTime?         @map("activation_expires")
  resetToken        String?           @unique @map("reset_token")
  resetExpires      DateTime?         @map("reset_expires")

  // Links
  cabinetId         String            @map("cabinet_id")
  cabinet           Cabinet           @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  folderId          String?           @map("folder_id")
  folder            Folder?           @relation(fields: [folderId], references: [id], onDelete: SetNull)
  clientId          String?           @map("client_id")
  client            Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // Permissions
  allowedFolders    String[]          @default([]) @map("allowed_folders")
  permissions       Json              @default("{\"canSign\":true,\"canDownload\":true,\"canComment\":false}")

  // Tracking
  lastLoginAt       DateTime?         @map("last_login_at")
  loginCount        Int               @default(0) @map("login_count")
  accessLogs        ClientAccessLog[]

  // Metadata
  invitedBy         String            @map("invited_by")
  invitedAt         DateTime          @default(now()) @map("invited_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  @@index([cabinetId])
  @@index([email])
  @@index([activationToken])
  @@index([resetToken])
  @@index([clientId])
  @@map("client_accesses")
}

/// Log of client portal access actions
model ClientAccessLog {
  id              String        @id @default(cuid())
  clientAccessId  String        @map("client_access_id")
  clientAccess    ClientAccess  @relation(fields: [clientAccessId], references: [id], onDelete: Cascade)

  action          ClientAccessAction
  documentId      String?       @map("document_id")
  folderId        String?       @map("folder_id")
  ipAddress       String?       @map("ip_address")
  userAgent       String?       @map("user_agent")
  details         Json?

  timestamp       DateTime      @default(now())

  @@index([clientAccessId])
  @@index([timestamp])
  @@index([action])
  @@map("client_access_logs")
}

/// Log of reminder emails sent for document tracking
model ReminderLog {
  id                String           @id @default(cuid())
  trackingId        String           @map("tracking_id")
  tracking          DocumentTracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)

  reminderNumber    Int              @map("reminder_number")
  sentTo            String           @map("sent_to")
  sentAt            DateTime         @default(now()) @map("sent_at")
  emailSubject      String           @map("email_subject")
  emailBody         String           @map("email_body") @db.Text

  opened            Boolean          @default(false)
  openedAt          DateTime?        @map("opened_at")
  clicked           Boolean          @default(false)
  clickedAt         DateTime?        @map("clicked_at")

  @@index([trackingId])
  @@index([sentAt])
  @@map("reminder_logs")
}

enum ClientAccessAction {
  LOGIN
  LOGOUT
  VIEW_DOCUMENT
  DOWNLOAD_DOCUMENT
  SIGN_DOCUMENT
  VIEW_FOLDER
  PASSWORD_RESET
}
